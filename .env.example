# Find your Divoom Time Gate IP address:
# 1. Open the Divoom app on your phone
# 2. Go to Device Settings
# 3. Tap on "Device Info" or "Network Info"
# 4. Copy the IP address shown (e.g., 192.168.1.100)

DIVOOM_IP=192.168.1.100

# Home Assistant Configuration:
# 1. Go to your Home Assistant profile
# 2. Scroll down to "Long-Lived Access Tokens"
# 3. Click "Create Token"
# 4. Copy the token and paste it below

HOME_ASSISTANT_URL=https://your-home-assistant.duckdns.org
HOME_ASSISTANT_TOKEN=your_long_lived_access_token

# Steps API Configuration (for step count generators):
STEPS_API_URL=https://your-appsync-api.amazonaws.com/graphql
STEPS_API_KEY=your_api_key
STEPS_AUTH_KEY=your_auth_key
JOHN_USER_ID=your_john_user_id
EMILY_USER_ID=your_emily_user_id
